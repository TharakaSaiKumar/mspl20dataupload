{
  "MongoDB": {
    "ConnectionString": "mongodb://mongodevuser:swfweew3@192.168.1.5:27017",
    "DatabaseName": "MSPL_USM_DEV"
  },
  "Application": {
    "TemplateDirectory": "Templates",
    "FormatsFile": "formats.json",
    "ReferenceSuffix": "/00",
    "ModuleMappings": {
      "USERS": "USR",
      "DESIGNATIONS": "DSG",
      "DEPARTMENTS": "DEP"
    },
    "LookupMappings": {
      "activeStatus": {
        "InputType": "static",
        "InputValue": "ACT",
        "Collection": "rootStatusMaster",
        "LookupPath": "statusCode",
        "OutputType": "objectid",
        "OutputPath": "_id"
      },
      "primaryUnit": {
        "InputType": "excel",
        "InputColumn": "primaryUnitCode",
        "Collection": "masterUnits",
        "LookupPath": "unitInformation.unitCode",
        "OutputType": "object",
        "Mappings": {
          "itemID": "_id",
          "itemCode": "unitInformation.unitCode",
          "item": "unitInformation.unitName",
          "displayData": "unitInformation.formattedName",
          "itemActualID": "_id"
        }
      },
      "primaryDepartment": {
        "InputType": "excel",
        "InputColumn": "primaryDepartmentCode",
        "Collection": "masterDepartments",
        "LookupPath": "departments.departmentCode",
        "OutputType": "object",
        "Mappings": {
          "itemID": "_id",
          "itemCode": "departments.departmentCode",
          "item": "departments.departmentName",
          "displayData": "departments.formattedName",
          "itemActualID": "_id"
        }
      },
      "block": {
        "InputType": "excel",
        "InputColumn": "blockCode",
        "Collection": "masterBlocks",
        "LookupPath": "blocks.blockCode",
        "OutputType": "object",
        "Mappings": {
          "itemID": "_id",
          "itemCode": "blocks.blockCode",
          "item": "blocks.blockName",
          "displayData": "blocks.formattedName",
          "itemActualID": "_id"
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
